# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant_enterprise
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/restaurant_enterprise

# Flask Configuration
FLASK_SECRET=change-me-in-production
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
SESSION_COOKIE_SECURE=0
FLASK_DEBUG=0
FLASK_ENV=production

# Security
RAMO_DEFAULT_ADMIN_PASSWORD=admin123
ENABLE_LEGACY_AUTOMIGRATE=0

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Enterprise Features
ENABLE_ANALYTICS=1
ENABLE_KITCHEN_DISPLAY=1
ENABLE_STAFF_MANAGEMENT=1
ENABLE_CUSTOMER_ANALYTICS=1
ENABLE_RECIPE_COSTING=1

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30
ENABLE_CORS=1

# Monitoring
ENABLE_METRICS=1
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Payment Gateway
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Performance
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=2

# SSL Configuration
SSL_CERT_PATH=nginx/ssl/cert.pem
SSL_KEY_PATH=nginx/ssl/key.pem
NGINX_PORT=80
NGINX_SSL_PORT=443

# Development Override
# Uncomment for development
# FLASK_DEBUG=1
# FLASK_ENV=development
