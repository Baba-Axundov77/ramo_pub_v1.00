# ═══════════════════════════════════════════════════════════════
# RAMO PUB - PRODUCTION ENVIRONMENT CONFIGURATION
# SECURITY: Keep this file private and never commit to version control
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (High-Security + Connection Pool)
# ═══════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=ramo_pub
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_32_CHARS_MIN

# DATABASE CONNECTION POOL (Optimized for Restaurant Operations)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false
DB_POOL_RESET_ON_RETURN=commit

# LEGACY DATABASE URL (for compatibility)
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_THIS_SECURE_PASSWORD_32_CHARS_MIN@localhost:5432/ramo_pub

# ═══════════════════════════════════════════════════════════════
# APPLICATION SECURITY (CRITICAL - CHANGE IN PRODUCTION)
# ═══════════════════════════════════════════════════════════════
FLASK_SECRET=CHANGE_THIS_32_CHAR_SECRET_KEY_IN_PRODUCTION
SECRET_KEY=CHANGE_THIS_32_CHAR_SECRET_KEY_IN_PRODUCTION
JWT_SECRET_KEY=CHANGE_THIS_32_CHAR_JWT_SECRET_KEY_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
FLASK_DEBUG=false
FLASK_ENV=production

# ═══════════════════════════════════════════════════════════════
# WEB SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_GREEN_PORT=5001  # For blue-green deployment

# ═══════════════════════════════════════════════════════════════
# REDIS CONFIGURATION (Caching & Session Storage)
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════
RAMO_DEFAULT_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_12_CHARS_MIN
ENABLE_RUNTIME_AUTO_MIGRATE=false
ALLOW_NEGATIVE_STOCK=false
API_KEY=CHANGE_THIS_32_CHAR_API_KEY_FOR_EXTERNAL_INTEGRATIONS
CORS_ORIGINS=https://ramo-pub.com,https://www.ramo-pub.com
RATE_LIMIT_PER_MINUTE=100
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=900  # 15 minutes

# ═══════════════════════════════════════════════════════════════
# ENTERPRISE FEATURES
# ═══════════════════════════════════════════════════════════════
ENABLE_ANALYTICS=true
ENABLE_KITCHEN_DISPLAY=true
ENABLE_STAFF_MANAGEMENT=true
ENABLE_CUSTOMER_ANALYTICS=true
ENABLE_RECIPE_COSTING=true
ENABLE_INVENTORY_MANAGEMENT=true
ENABLE_REPORTS=true
ENABLE_NOTIFICATIONS=true

# ═══════════════════════════════════════════════════════════════
# MONITORING & LOGGING (Production Ready)
# ═══════════════════════════════════════════════════════════════
# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=10
LOG_FORMAT=json

# Prometheus Metrics
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics

# Grafana Dashboard
GRAFANA_PORT=3000
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
GRAFANA_ADMIN_USER=admin

# ═══════════════════════════════════════════════════════════════
# PERFORMANCE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_CONCURRENCY=4
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# ═══════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Transactional)
# ═══════════════════════════════════════════════════════════════
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@ramo-pub.com
SMTP_PASSWORD=your-app-specific-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=noreply@ramo-pub.com
EMAIL_FROM_NAME=Ramo Pub

# SendGrid Configuration (Alternative)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@ramo-pub.com

# ═══════════════════════════════════════════════════════════════
# PAYMENT GATEWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_API_VERSION=2023-10-16

# ═══════════════════════════════════════════════════════════════
# SMS CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid

# ═══════════════════════════════════════════════════════════════
# FILE STORAGE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
UPLOAD_FOLDER=uploads
STATIC_FOLDER=static
MAX_CONTENT_LENGTH=52428800  # 50MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_FOLDER_ABSOLUTE=/app/uploads

# AWS S3 Configuration (Cloud Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ramo-pub-uploads
AWS_S3_CUSTOM_DOMAIN=uploads.ramo-pub.com

# ═══════════════════════════════════════════════════════════════
# SSL & HTTPS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FORCE_HTTPS=true

# Let's Encrypt Configuration
LETSENCRYPT_EMAIL=admin@ramo-pub.com
LETSENCRYPT_DOMAINS=ramo-pub.com,www.ramo-pub.com
LETSENCRYPT_STAGING=false

# ═══════════════════════════════════════════════════════════════
# BACKUP & DISASTER RECOVERY
# ═══════════════════════════════════════════════════════════════
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ramo-pub-backups
BACKUP_ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_BACKUP_KEY

# ═══════════════════════════════════════════════════════════════
# BLUE-GREEN DEPLOYMENT
# ═══════════════════════════════════════════════════════════════
DEPLOYMENT_ENVIRONMENT=production
CURRENT_ENVIRONMENT=blue  # blue or green
HEALTH_CHECK_TIMEOUT=30
DEPLOYMENT_STRATEGY=blue-green
ZERO_DOWNTIME_DEPLOYMENT=true

# ═══════════════════════════════════════════════════════════════
# DEVELOPMENT & TESTING (Comment out in production)
# ═══════════════════════════════════════════════════════════════
# Uncomment for development environment:
# FLASK_DEBUG=true
# FLASK_ENV=development
# LOG_LEVEL=DEBUG
# ENABLE_RUNTIME_AUTO_MIGRATE=true
# SESSION_COOKIE_SECURE=false
# CORS_ORIGINS=*
# SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════
# SECURITY CHECKLIST (Before Production Deployment):
# ═══════════════════════════════════════════════════════════════
# [ ] Change all passwords and secret keys
# [ ] Set up SSL certificates (Let's Encrypt)
# [ ] Configure Sentry error tracking
# [ ] Set up backup encryption
# [ ] Configure email/SMS services
# [ ] Set up payment gateway (Stripe)
# [ ] Configure CORS origins properly
# [ ] Enable rate limiting
# [ ] Set up monitoring (Prometheus/Grafana)
# [ ] Test blue-green deployment
# [ ] Verify all environment variables
# [ ] Run security scans
# ═══════════════════════════════════════════════════════════════
